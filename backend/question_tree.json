      "type": "single_choice",
      "options": [
        { "label": "Hard to fall asleep",       "value": "onset",       "next": "lifestyle_stress" },
        { "label": "Wake up frequently",        "value": "maintenance", "next": "lifestyle_stress" },
        { "label": "Wake up too early",         "value": "early_wake",  "next": "lifestyle_stress" },
        { "label": "Never feel refreshed",      "value": "quality",     "next": "lifestyle_stress" }
      ]
    },
    "stress": {
      "id": "concern_stress_detail",
      "text": "You flagged stress as a concern 🧘. How does it usually show up for you?",
      "type": "single_choice",
      "options": [
        { "label": "Headaches & tension",        "value": "physical",   "next": "lifestyle_sleep" },
        { "label": "Overthinking / anxiety",     "value": "mental",     "next": "lifestyle_sleep" },
        { "label": "Irritability & mood swings", "value": "emotional",  "next": "lifestyle_sleep" },
        { "label": "Fatigue & burnout",          "value": "burnout",    "next": "lifestyle_sleep" }
