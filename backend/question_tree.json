        { "label": "Afternoon slump",            "value": "afternoon",  "next": "lifestyle_sleep" },
        { "label": "All day exhaustion",         "value": "all_day",    "next": "lifestyle_sleep" }
      ]
    },
    "gut": {
      "id": "concern_gut_detail",
      "text": "Gut health flagged 🌿. Which best describes your experience?",
      "type": "single_choice",
      "options": [
        { "label": "Bloating & gas",         "value": "bloating",   "next": "lifestyle_water" },
        { "label": "Constipation",           "value": "constipation","next": "lifestyle_water" },
        { "label": "Acid reflux / acidity",  "value": "acidity",    "next": "lifestyle_water" },
